{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "codelens-hook enforce"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "codelens-hook memory"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "codelens-hook bash"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "codelens-hook read"
          }
        ]
      },
      {
        "matcher": "Glob",
        "hooks": [
          {
            "type": "command",
            "command": "codelens-hook glob"
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "codelens": {
      "command": "codelens",
      "args": ["serve"],
      "env": {
        "CODELENS_PROJECT": ".",
        "CODELENS_OLLAMA_URL": "http://localhost:11434",
        "CODELENS_OLLAMA_MODEL": "nomic-embed-text"
      }
    }
  }
}
